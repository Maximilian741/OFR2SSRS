# Oracle2SSRS — environment configuration
# Copy this file to ".env" (which is gitignored) and fill in your values.

# Anthropic API key — required for the "Auto-fix with AI" button.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the model. Default is claude-haiku-4-5 (cheapest + fast).
# Other options: claude-sonnet-4-6 (better, slower, more expensive)
# O2S_AI_MODEL=claude-haiku-4-5

# Optional: cap response size per AI call. Default 1500.
# O2S_AI_MAX_TOKENS=1500
