<?xml version="1.0" encoding="WINDOWS-1252" ?>
<report name="COMPLEX_REPORT" DTDVersion="9.0.2.0.10"
 afterParameterFormTrigger="after_param_form">
  <xmlSettings xmlTag="COMPLEX_REPORT" xmlPrologType="text">
  <![CDATA[<?xml version="1.0" encoding="&Encoding"?>]]>
  </xmlSettings>
  <reportHtmlEscapes>
    <beforePageHtmlEscape>
    <![CDATA[#NULL#]]>
    </beforePageHtmlEscape>
  </reportHtmlEscapes>
  <data>
    <userParameter name="P_AS_OF_DATE" datatype="date" width="10"
     precision="10" inputMask="MM/DD/YYYY" label="As Of Date"
     defaultWidth="0" defaultHeight="0"/>
    <userParameter name="P_FISCAL_YEAR" datatype="number" width="4"
     precision="10" initialValue="2025" label="Fiscal Year"
     defaultWidth="0" defaultHeight="0"/>
    <userParameter name="P_DIVISION" datatype="character" width="30"
     precision="10" label="Division" defaultWidth="0" defaultHeight="0"/>
    <userParameter name="P_INCLUDE_INACTIVE" datatype="character" width="1"
     precision="10" initialValue="N" label="Include Inactive"
     defaultWidth="0" defaultHeight="0"/>
    <userParameter name="P_MIN_SALARY" datatype="number" width="10"
     precision="10" initialValue="0" label="Min Salary"
     defaultWidth="0" defaultHeight="0"/>
    <userParameter name="P_MAX_SALARY" datatype="number" width="10"
     precision="10" initialValue="9999999" label="Max Salary"
     defaultWidth="0" defaultHeight="0"/>
    <userParameter name="P_SORT_BY" datatype="character" width="20"
     precision="10" initialValue="DIVISION" label="Sort By"
     defaultWidth="0" defaultHeight="0"/>
    <userParameter name="P_REPORT_TITLE" datatype="character" width="200"
     precision="10" initialValue="Corporate Compensation Report"
     label="Report Title" defaultWidth="0" defaultHeight="0"/>
    <userParameter name="P_CRITERIA_DIV" datatype="character" width="4000"
     precision="10" label="P Criteria Div" defaultWidth="0"
     defaultHeight="0" display="no"/>
    <userParameter name="P_CRITERIA_DEPT" datatype="character" width="4000"
     precision="10" label="P Criteria Dept" defaultWidth="0"
     defaultHeight="0" display="no"/>
    <dataSource name="Q_DIVISION">
      <select>
      <![CDATA[SELECT
	DIV.div_id,
	DIV.div_name,
	DIV.div_code,
	NVL(DIV.headcount_target, 0) Headcount_Target,
	DECODE(DIV.active_flag, 'Y', 'Active', 'N', 'Inactive') Div_Status
FROM
	divisions DIV
WHERE
	UPPER(DIV.div_name) = UPPER(:P_DIVISION)
	AND DIV.fiscal_year = :P_FISCAL_YEAR
	&P_CRITERIA_DIV
ORDER BY
	DIV.div_name]]>
      </select>
      <displayInfo x="0.25000" y="0.25000" width="1.75000" height="0.25000"/>
      <group name="G_DIVISION">
        <displayInfo x="0.25000" y="0.75000" width="1.75000" height="2.50000"/>
        <dataItem name="Div_Id" oracleDatatype="number" columnOrder="1"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Div Id" breakOrder="none">
          <dataDescriptor expression="DIV.div_id"
           descriptiveExpression="DIV_ID" order="1" oracleDatatype="number"
           width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Div_Name" datatype="vchar2" columnOrder="2"
         width="100" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Div Name" breakOrder="none">
          <dataDescriptor expression="DIV.div_name"
           descriptiveExpression="DIV_NAME" order="2" width="100"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Div_Code" datatype="vchar2" columnOrder="3"
         width="20" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Div Code" breakOrder="none">
          <dataDescriptor expression="DIV.div_code"
           descriptiveExpression="DIV_CODE" order="3" width="20"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Headcount_Target" oracleDatatype="number"
         columnOrder="4" width="22" defaultWidth="120000"
         defaultHeight="10000" columnFlags="0"
         defaultLabel="Headcount Target" breakOrder="none">
          <dataDescriptor
           expression="NVL ( DIV.headcount_target , 0 )"
           descriptiveExpression="HEADCOUNT_TARGET" order="4"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Div_Status" datatype="vchar2" columnOrder="5"
         width="20" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Div Status" breakOrder="none">
          <dataDescriptor
           expression="DECODE ( DIV.active_flag , &apos;Y&apos; , &apos;Active&apos; , &apos;N&apos; , &apos;Inactive&apos; )"
           descriptiveExpression="DIV_STATUS" order="5" width="20"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <formula name="CF_Org_Tree_F" source="cf_org_tree_f"
         datatype="character" width="2000" precision="10"
         defaultWidth="100000" defaultHeight="10000" columnFlags="16"
         defaultLabel="Cf Org Tree" breakOrder="none">
          <displayInfo x="0.00000" y="0.00000" width="0.00000" height="0.00000"/>
        </formula>
      </group>
    </dataSource>
    <dataSource name="Q_DEPARTMENT">
      <select>
      <![CDATA[SELECT
	D.dept_id,
	D.div_id,
	D.dept_name,
	D.dept_code,
	D.parent_dept_id,
	NVL(D.cost_center, 'UNASSIGNED') Cost_Center,
	ROWNUM Row_Num
FROM
	departments D
WHERE
	D.div_id = :Div_Id
	AND D.fiscal_year = :P_FISCAL_YEAR
	&P_CRITERIA_DEPT
ORDER BY
	D.dept_name]]>
      </select>
      <displayInfo x="2.25000" y="0.25000" width="1.75000" height="0.25000"/>
      <group name="G_DEPARTMENT">
        <displayInfo x="2.25000" y="0.75000" width="1.75000" height="2.50000"/>
        <dataItem name="Dept_Id" oracleDatatype="number" columnOrder="1"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Dept Id" breakOrder="none">
          <dataDescriptor expression="D.dept_id"
           descriptiveExpression="DEPT_ID" order="1" oracleDatatype="number"
           width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Div_Id_Ref" oracleDatatype="number" columnOrder="2"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Div Id" breakOrder="none">
          <dataDescriptor expression="D.div_id"
           descriptiveExpression="DIV_ID" order="2" oracleDatatype="number"
           width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Dept_Name" datatype="vchar2" columnOrder="3"
         width="100" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Dept Name" breakOrder="none">
          <dataDescriptor expression="D.dept_name"
           descriptiveExpression="DEPT_NAME" order="3" width="100"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Dept_Code" datatype="vchar2" columnOrder="4"
         width="20" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Dept Code" breakOrder="none">
          <dataDescriptor expression="D.dept_code"
           descriptiveExpression="DEPT_CODE" order="4" width="20"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Parent_Dept_Id" oracleDatatype="number"
         columnOrder="5" width="22" defaultWidth="120000"
         defaultHeight="10000" columnFlags="0" defaultLabel="Parent Dept Id"
         breakOrder="none">
          <dataDescriptor expression="D.parent_dept_id"
           descriptiveExpression="PARENT_DEPT_ID" order="5"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Cost_Center" datatype="vchar2" columnOrder="6"
         width="40" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Cost Center" breakOrder="none">
          <dataDescriptor
           expression="NVL ( D.cost_center , &apos;UNASSIGNED&apos; )"
           descriptiveExpression="COST_CENTER" order="6" width="40"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Row_Num" oracleDatatype="number" columnOrder="7"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Row Num" breakOrder="none">
          <dataDescriptor expression="ROWNUM"
           descriptiveExpression="ROW_NUM" order="7"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <formula name="CF_Dept_Path_F" source="cf_dept_path_f"
         datatype="character" width="500" precision="10"
         defaultWidth="100000" defaultHeight="10000" columnFlags="16"
         defaultLabel="Cf Dept Path" breakOrder="none">
          <displayInfo x="0.00000" y="0.00000" width="0.00000" height="0.00000"/>
        </formula>
        <formula name="CF_Subordinate_List_F" source="cf_subordinate_list_f"
         datatype="character" width="2000" precision="10"
         defaultWidth="100000" defaultHeight="10000" columnFlags="16"
         defaultLabel="Cf Subordinate List" breakOrder="none">
          <displayInfo x="0.00000" y="0.00000" width="0.00000" height="0.00000"/>
        </formula>
        <summary name="CS_Dept_Salary_Total" source="Total_Comp_F"
         function="sum" width="22" precision="10" reset="G_DEPARTMENT"
         compute="report" defaultWidth="120000" defaultHeight="10000"
         columnFlags="8" defaultLabel="Cs Dept Salary Total">
          <displayInfo x="0.00000" y="0.00000" width="0.00000" height="0.00000"/>
        </summary>
      </group>
    </dataSource>
    <dataSource name="Q_EMPLOYEE">
      <select>
      <![CDATA[SELECT
	E.emp_id,
	E.dept_id,
	E.emp_name,
	E.job_title,
	E.hire_date,
	E.base_salary,
	NVL(E.bonus_pct, 0) Bonus_Pct,
	E.manager_id,
	E.active_flag
FROM
	employees E
WHERE
	E.dept_id = :Dept_Id
	AND E.base_salary BETWEEN :P_MIN_SALARY AND :P_MAX_SALARY
	AND (
		:P_INCLUDE_INACTIVE = 'Y'
		OR E.active_flag = 'Y'
	)
	AND E.hire_date <= :P_AS_OF_DATE
ORDER BY
	E.emp_name]]>
      </select>
      <displayInfo x="4.25000" y="0.25000" width="1.75000" height="0.25000"/>
      <group name="G_EMPLOYEE">
        <displayInfo x="4.25000" y="0.75000" width="1.75000" height="2.50000"/>
        <dataItem name="Emp_Id" oracleDatatype="number" columnOrder="1"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Emp Id" breakOrder="none">
          <dataDescriptor expression="E.emp_id"
           descriptiveExpression="EMP_ID" order="1" oracleDatatype="number"
           width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Dept_Id_Ref" oracleDatatype="number" columnOrder="2"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Dept Id" breakOrder="none">
          <dataDescriptor expression="E.dept_id"
           descriptiveExpression="DEPT_ID" order="2" oracleDatatype="number"
           width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Emp_Name" datatype="vchar2" columnOrder="3"
         width="100" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Emp Name" breakOrder="none">
          <dataDescriptor expression="E.emp_name"
           descriptiveExpression="EMP_NAME" order="3" width="100"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Job_Title" datatype="vchar2" columnOrder="4"
         width="60" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Job Title" breakOrder="none">
          <dataDescriptor expression="E.job_title"
           descriptiveExpression="JOB_TITLE" order="4" width="60"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Hire_Date" datatype="date" oracleDatatype="date"
         columnOrder="5" width="9" defaultWidth="90000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Hire Date" breakOrder="none">
          <dataDescriptor expression="E.hire_date"
           descriptiveExpression="HIRE_DATE" order="5"
           oracleDatatype="date" width="9"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Base_Salary" oracleDatatype="number" columnOrder="6"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Base Salary" breakOrder="none">
          <dataDescriptor expression="E.base_salary"
           descriptiveExpression="BASE_SALARY" order="6"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Bonus_Pct" oracleDatatype="number" columnOrder="7"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Bonus Pct" breakOrder="none">
          <dataDescriptor
           expression="NVL ( E.bonus_pct , 0 )"
           descriptiveExpression="BONUS_PCT" order="7"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Manager_Id" oracleDatatype="number" columnOrder="8"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Manager Id" breakOrder="none">
          <dataDescriptor expression="E.manager_id"
           descriptiveExpression="MANAGER_ID" order="8"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Active_Flag" datatype="vchar2" columnOrder="9"
         width="1" defaultWidth="20000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Active Flag" breakOrder="none">
          <dataDescriptor expression="E.active_flag"
           descriptiveExpression="ACTIVE_FLAG" order="9" width="1"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <formula name="CF_Total_Comp_F" source="cf_total_comp_f"
         datatype="number" width="22" precision="10" defaultWidth="120000"
         defaultHeight="10000" columnFlags="16" defaultLabel="Cf Total Comp"
         breakOrder="none">
          <displayInfo x="0.00000" y="0.00000" width="0.00000" height="0.00000"/>
        </formula>
        <formula name="CF_Tenure_Years_F" source="cf_tenure_years_f"
         datatype="number" width="22" precision="10" defaultWidth="120000"
         defaultHeight="10000" columnFlags="16" defaultLabel="Cf Tenure Years"
         breakOrder="none">
          <displayInfo x="0.00000" y="0.00000" width="0.00000" height="0.00000"/>
        </formula>
        <formula name="CF_Manager_Chain_F" source="cf_manager_chain_f"
         datatype="character" width="2000" precision="10"
         defaultWidth="100000" defaultHeight="10000" columnFlags="16"
         defaultLabel="Cf Manager Chain" breakOrder="none">
          <displayInfo x="0.00000" y="0.00000" width="0.00000" height="0.00000"/>
        </formula>
      </group>
    </dataSource>
    <dataSource name="Q_BENEFITS">
      <select>
      <![CDATA[SELECT
	B.emp_id,
	B.benefit_type,
	B.benefit_amt,
	B.effective_date
FROM
	benefits B
WHERE
	B.emp_id = :Emp_Id
	AND B.effective_date <= :P_AS_OF_DATE
ORDER BY
	B.benefit_type]]>
      </select>
      <displayInfo x="6.25000" y="0.25000" width="1.75000" height="0.25000"/>
      <group name="G_BENEFITS">
        <displayInfo x="6.25000" y="0.75000" width="1.75000" height="2.50000"/>
        <dataItem name="Emp_Id_Ref" oracleDatatype="number" columnOrder="1"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Emp Id" breakOrder="none">
          <dataDescriptor expression="B.emp_id"
           descriptiveExpression="EMP_ID" order="1" oracleDatatype="number"
           width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Benefit_Type" datatype="vchar2" columnOrder="2"
         width="40" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Benefit Type" breakOrder="none">
          <dataDescriptor expression="B.benefit_type"
           descriptiveExpression="BENEFIT_TYPE" order="2" width="40"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Benefit_Amt" oracleDatatype="number" columnOrder="3"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Benefit Amt" breakOrder="none">
          <dataDescriptor expression="B.benefit_amt"
           descriptiveExpression="BENEFIT_AMT" order="3"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Effective_Date" datatype="date" oracleDatatype="date"
         columnOrder="4" width="9" defaultWidth="90000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Effective Date" breakOrder="none">
          <dataDescriptor expression="B.effective_date"
           descriptiveExpression="EFFECTIVE_DATE" order="4"
           oracleDatatype="date" width="9"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
      </group>
    </dataSource>
    <link parentGroup="G_DIVISION" childQuery="Q_DEPARTMENT" condition="eq"
     sqlClause="where"/>
    <link parentGroup="G_DEPARTMENT" childQuery="Q_EMPLOYEE" condition="eq"
     sqlClause="where"/>
    <link parentGroup="G_EMPLOYEE" childQuery="Q_BENEFITS" condition="eq"
     sqlClause="where"/>
  </data>
  <programUnits>
    <function name="cf_org_tree_f" returnType="character">
      <textSource>
      <![CDATA[FUNCTION CF_Org_Tree_F
RETURN VARCHAR2 IS
	vTree	VARCHAR2(2000) ;
BEGIN
	SELECT
		LISTAGG(LPAD(' ', 2 * (LEVEL - 1)) || dept_name, CHR(10))
			WITHIN GROUP (ORDER BY dept_name) Tree
	INTO
		vTree
	FROM
		departments
	WHERE
		div_id = :Div_Id
	START WITH
		parent_dept_id IS NULL
	CONNECT BY
		PRIOR dept_id = parent_dept_id ;

	RETURN(vTree) ;
END ;]]>
      </textSource>
    </function>
    <function name="cf_dept_path_f" returnType="character">
      <textSource>
      <![CDATA[FUNCTION CF_Dept_Path_F
RETURN VARCHAR2 IS
	vPath	VARCHAR2(500) ;
BEGIN
	SELECT
		SYS_CONNECT_BY_PATH(dept_name, ' / ') Path
	INTO
		vPath
	FROM
		departments
	WHERE
		dept_id = :Dept_Id
	START WITH
		parent_dept_id IS NULL
	CONNECT BY
		PRIOR dept_id = parent_dept_id ;

	RETURN(LTRIM(vPath, ' / ')) ;
EXCEPTION
WHEN NO_DATA_FOUND THEN
	RETURN(NULL) ;
END ;]]>
      </textSource>
    </function>
    <function name="cf_subordinate_list_f" returnType="character">
      <textSource>
      <![CDATA[FUNCTION CF_Subordinate_List_F
RETURN VARCHAR2 IS
	vList	VARCHAR2(2000) ;
BEGIN
	SELECT
		LISTAGG(dept_name, '; ') WITHIN GROUP (ORDER BY dept_name) Subord
	INTO
		vList
	FROM
		departments
	WHERE
		parent_dept_id = :Dept_Id ;

	RETURN(vList) ;
END ;]]>
      </textSource>
    </function>
    <function name="cf_total_comp_f" returnType="number">
      <textSource>
      <![CDATA[FUNCTION CF_Total_Comp_F
RETURN NUMBER IS
	nBonus	NUMBER ;
BEGIN
	nBonus := NVL(:Base_Salary, 0) * NVL(:Bonus_Pct, 0) / 100 ;
	RETURN(NVL(:Base_Salary, 0) + nBonus) ;
END ;]]>
      </textSource>
    </function>
    <function name="cf_tenure_years_f" returnType="number">
      <textSource>
      <![CDATA[FUNCTION CF_Tenure_Years_F
RETURN NUMBER IS
BEGIN
	IF :Hire_Date IS NULL THEN
		RETURN(0) ;
	END IF ;

	RETURN(TRUNC(MONTHS_BETWEEN(:P_AS_OF_DATE, :Hire_Date) / 12, 1)) ;
END ;]]>
      </textSource>
    </function>
    <function name="cf_manager_chain_f" returnType="character">
      <textSource>
      <![CDATA[FUNCTION CF_Manager_Chain_F
RETURN VARCHAR2 IS
	vChain	VARCHAR2(2000) ;
BEGIN
	SELECT
		LISTAGG(emp_name, ' -> ') WITHIN GROUP (ORDER BY LEVEL DESC) Chain
	INTO
		vChain
	FROM
		employees
	START WITH
		emp_id = :Emp_Id
	CONNECT BY
		PRIOR manager_id = emp_id ;

	RETURN(vChain) ;
EXCEPTION
WHEN NO_DATA_FOUND THEN
	RETURN(:Emp_Name) ;
END ;]]>
      </textSource>
    </function>
    <function name="b_emp_format_ft">
      <textSource>
      <![CDATA[FUNCTION B_Emp_Format_FT
RETURN BOOLEAN IS
BEGIN
	IF :Active_Flag = 'N' THEN
		SRW.Set_Foreground_Border_Color('gray') ;
		SRW.Set_Text_Color('gray') ;
	END IF ;

	IF NVL(:CF_Total_Comp_F, 0) > 200000 THEN
		SRW.Set_Text_Color('red') ;
	END IF ;

	RETURN(TRUE) ;
END ;]]>
      </textSource>
    </function>
    <function name="b_div_page_break_ft">
      <textSource>
      <![CDATA[FUNCTION B_Div_Page_Break_FT
RETURN BOOLEAN IS
BEGIN
	SRW.Set_Page_Break_Before(TRUE) ;
	RETURN(TRUE) ;
END ;]]>
      </textSource>
    </function>
    <function name="after_param_form">
      <textSource>
      <![CDATA[FUNCTION After_Param_Form
RETURN BOOLEAN IS
	vCriteriaDiv	VARCHAR2(4000) ;
	vCriteriaDept	VARCHAR2(4000) ;
BEGIN
	vCriteriaDiv := NULL ;
	vCriteriaDept := NULL ;

	IF :P_INCLUDE_INACTIVE = 'N' THEN
		vCriteriaDiv := vCriteriaDiv || ' AND DIV.active_flag = ''Y'' ' ;
		vCriteriaDept := vCriteriaDept || ' AND D.active_flag = ''Y'' ' ;
	END IF ;

	IF UPPER(NVL(:P_SORT_BY, 'DIVISION')) = 'COSTCENTER' THEN
		vCriteriaDept := vCriteriaDept || ' AND D.cost_center IS NOT NULL ' ;
	END IF ;

	:P_CRITERIA_DIV := vCriteriaDiv ;
	:P_CRITERIA_DEPT := vCriteriaDept ;

	IF :P_AS_OF_DATE IS NULL THEN
		:P_AS_OF_DATE := TRUNC(SYSDATE) ;
	END IF ;

	RETURN(TRUE) ;
END ;]]>
      </textSource>
    </function>
  </programUnits>
</report>
