<?xml version="1.0" encoding="WINDOWS-1252" ?>
<report name="MASTER_DETAIL" DTDVersion="9.0.2.0.10"
 afterParameterFormTrigger="after_param_form">
  <xmlSettings xmlTag="MASTER_DETAIL" xmlPrologType="text">
  <![CDATA[<?xml version="1.0" encoding="&Encoding"?>]]>
  </xmlSettings>
  <data>
    <userParameter name="P_REGION" datatype="character" width="30"
     precision="10" label="Region" defaultWidth="0" defaultHeight="0"/>
    <userParameter name="P_YEAR" datatype="number" width="4"
     precision="10" initialValue="2025" label="Year" defaultWidth="0"
     defaultHeight="0"/>
    <userParameter name="P_REPORT_DATE" datatype="date" width="10"
     precision="10" inputMask="MM/DD/YYYY" label="Report Date"
     defaultWidth="0" defaultHeight="0"/>
    <dataSource name="Q_DEPT">
      <select>
      <![CDATA[SELECT
	D.dept_id,
	D.dept_name,
	NVL(R.region_name, 'UNASSIGNED') Region,
	DECODE(D.active_flag, 'Y', 'Active', 'N', 'Inactive', 'Unknown') Status,
	D.budget_amt
FROM
	departments D,
	regions R
WHERE
	D.region_id = R.region_id (+)
	AND UPPER(NVL(R.region_name, 'UNASSIGNED')) = UPPER(:P_REGION)
	AND D.fiscal_year = :P_YEAR
ORDER BY
	D.dept_name]]>
      </select>
      <displayInfo x="0.50000" y="0.50000" width="1.75000" height="0.25000"/>
      <group name="G_DEPT">
        <displayInfo x="0.50000" y="1.00000" width="1.75000" height="2.50000"/>
        <dataItem name="Dept_Id" oracleDatatype="number" columnOrder="1"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Dept Id" breakOrder="none">
          <dataDescriptor expression="D.dept_id"
           descriptiveExpression="DEPT_ID" order="1" oracleDatatype="number"
           width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Dept_Name" datatype="vchar2" columnOrder="2"
         width="100" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Dept Name" breakOrder="none">
          <dataDescriptor expression="D.dept_name"
           descriptiveExpression="DEPT_NAME" order="2" width="100"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Region" datatype="vchar2" columnOrder="3"
         width="30" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Region" breakOrder="none">
          <dataDescriptor
           expression="NVL ( R.region_name , &apos;UNASSIGNED&apos; )"
           descriptiveExpression="REGION" order="3" width="30"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Status" datatype="vchar2" columnOrder="4"
         width="20" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Status" breakOrder="none">
          <dataDescriptor
           expression="DECODE ( D.active_flag , &apos;Y&apos; , &apos;Active&apos; , &apos;N&apos; , &apos;Inactive&apos; , &apos;Unknown&apos; )"
           descriptiveExpression="STATUS" order="4" width="20"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Budget_Amt" oracleDatatype="number" columnOrder="5"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Budget Amt" breakOrder="none">
          <dataDescriptor expression="D.budget_amt"
           descriptiveExpression="BUDGET_AMT" order="5"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
      </group>
    </dataSource>
    <dataSource name="Q_EMP_DETAIL">
      <select>
      <![CDATA[SELECT
	E.emp_id,
	E.dept_id,
	E.emp_name,
	E.hire_date,
	E.base_salary,
	NVL(E.bonus_pct, 0) Bonus_Pct
FROM
	employees E
WHERE
	E.dept_id = :Dept_Id
	AND E.hire_date <= :P_REPORT_DATE
ORDER BY
	E.emp_name]]>
      </select>
      <displayInfo x="2.50000" y="0.50000" width="1.75000" height="0.25000"/>
      <group name="G_EMP_DETAIL">
        <displayInfo x="2.50000" y="1.00000" width="1.75000" height="2.50000"/>
        <dataItem name="Emp_Id" oracleDatatype="number" columnOrder="1"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Emp Id" breakOrder="none">
          <dataDescriptor expression="E.emp_id"
           descriptiveExpression="EMP_ID" order="1" oracleDatatype="number"
           width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Dept_Id_Ref" oracleDatatype="number" columnOrder="2"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Dept Id" breakOrder="none">
          <dataDescriptor expression="E.dept_id"
           descriptiveExpression="DEPT_ID" order="2" oracleDatatype="number"
           width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Emp_Name" datatype="vchar2" columnOrder="3"
         width="100" defaultWidth="100000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Emp Name" breakOrder="none">
          <dataDescriptor expression="E.emp_name"
           descriptiveExpression="EMP_NAME" order="3" width="100"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Hire_Date" datatype="date" oracleDatatype="date"
         columnOrder="4" width="9" defaultWidth="90000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Hire Date" breakOrder="none">
          <dataDescriptor expression="E.hire_date"
           descriptiveExpression="HIRE_DATE" order="4"
           oracleDatatype="date" width="9"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Base_Salary" oracleDatatype="number" columnOrder="5"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Base Salary" breakOrder="none">
          <dataDescriptor expression="E.base_salary"
           descriptiveExpression="BASE_SALARY" order="5"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <dataItem name="Bonus_Pct" oracleDatatype="number" columnOrder="6"
         width="22" defaultWidth="120000" defaultHeight="10000"
         columnFlags="0" defaultLabel="Bonus Pct" breakOrder="none">
          <dataDescriptor
           expression="NVL ( E.bonus_pct , 0 )"
           descriptiveExpression="BONUS_PCT" order="6"
           oracleDatatype="number" width="22" precision="10"/>
          <dataItemPrivate adtName="" schemaName=""/>
        </dataItem>
        <formula name="CF_Total_Compensation_F" source="cf_total_compensation_f"
         datatype="number" width="22" precision="10" defaultWidth="120000"
         defaultHeight="10000" columnFlags="16"
         defaultLabel="Cf Total Compensation" breakOrder="none">
          <displayInfo x="0.00000" y="0.00000" width="0.00000" height="0.00000"/>
        </formula>
      </group>
    </dataSource>
    <link parentGroup="G_DEPT" childQuery="Q_EMP_DETAIL" condition="eq"
     sqlClause="where"/>
  </data>
  <programUnits>
    <function name="cf_total_compensation_f" returnType="number">
      <textSource>
      <![CDATA[FUNCTION CF_Total_Compensation_F
RETURN NUMBER IS
	nBonus	NUMBER ;
BEGIN
	nBonus := Pkg_HR_Util.F_Calc_Bonus(
				piEmp_Id => :Emp_Id,
				pnBase_Salary => :Base_Salary,
				pnBonus_Pct => :Bonus_Pct) ;

	RETURN(NVL(:Base_Salary, 0) + NVL(nBonus, 0)) ;
END ;]]>
      </textSource>
    </function>
    <function name="after_param_form">
      <textSource>
      <![CDATA[FUNCTION After_Param_Form
RETURN BOOLEAN IS
BEGIN
	IF :P_REGION IS NULL THEN
		:P_REGION := 'UNASSIGNED' ;
	END IF ;

	IF :P_REPORT_DATE IS NULL THEN
		:P_REPORT_DATE := TRUNC(SYSDATE) ;
	END IF ;

	RETURN(TRUE) ;
END ;]]>
      </textSource>
    </function>
  </programUnits>
</report>
