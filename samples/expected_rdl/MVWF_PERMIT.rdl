<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <rd:ReportID>00000000-0000-0000-0000-000000000000</rd:ReportID>
  <Description>MVWF_PERMIT</Description>
  <Author>Oracle2SSRS</Author>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DS_Main">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=localhost;Initial Catalog=DEQ</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Q_PERMIT">
      <Query>
        <DataSourceName>DS_Main</DataSourceName>
        <CommandText>SELECT 
	DECODE(UPPER(TRIM(@P_SORT)), 
		'COUNTY', C.Cnty_Nm || ' - ' || S.Site_Name, 
		'PERMITTEE', Pkg_WUTM_Util.F_Get_Permittees(
			                  P.Perm_Num,
			                  P.Prog_Id,
			                  P.Perm_Exp_Date, 
			                  'LAST_FIRST', 
			                  '; ') 
				|| ' - ' 
				|| P.Perm_Name, 
		'SITE', S.Site_Name,
		P.Perm_Name) Col_Sort, 		
	P.Perm_Num,
	P.Perm_Name Permit, 
	TO_CHAR(P.Perm_Eff_Date, 'YYYY') Renewal_Year, 
	'DEPARTMENT OF ENVIRONMENTAL QUALITY'
		|| CHR(10)
		|| UPPER(PT.Perm_Type_Desc) || ' LICENSE' Perm_Type, 	
	S.Site_Id, 
	S.Site_Name Site_Name, 
	Pkg_WUTM_Util.F_Format_Address(
		GLI.Addr_Strt_1, 
		GLI.Addr_Strt_2, 
		GLI.Addr_City, 
		GLI.Addr_St, 
		GLI.Addr_Zip, 
		GLI.Addr_Zip_Plus_4) Site_Addr, 
	P.Perm_Eff_Date, 	
	P.Perm_Exp_Date, 	
	TO_CHAR(P.Perm_Exp_Date, 'fmMONTH DD, YYYY') Exp_Date, 	
	TO_CHAR(P.Perm_Eff_Date, 'fmMONTH DD, YYYY')
		|| ' TO ' 
		|| TO_CHAR(P.Perm_Exp_Date, 'fmMONTH DD, YYYY') Perm_Dates,
	P.Prog_Id
FROM
	Permit_Type PT, 
	Permit P, 
	Status_Type ST,
	Application A,
	Site_Affiliation SA, 
	Site S, 
	Geo_Loc_Info GLI,
	Counties C
WHERE
	PT.Perm_Type_Id = P.Perm_Type_Id
	AND P.Stat_Type_Id = ST.Stat_Type_Id
	AND P.Perm_Num = A.Perm_Num 
	AND A.Site_Affil_Id = SA.Site_Affil_Id
	AND SA.Site_Id = S.Site_Id
	AND S.Site_Id = GLI.Site_Id 
	AND GLI.Cnty_Id = C.Cnty_Id(+)
	AND PT.Perm_Type_Name = 'MVWF'
	AND ST.Stat_Type_Name = 'JVA'
	AND EXISTS(		
		SELECT *
		FROM
			Application A2
		WHERE
			A2.Perm_Num = P.Perm_Num
		GROUP BY
			A2.Perm_Num
		HAVING
			MAX(A2.App_Name) = A.App_Name)
	&amp;P_CRITERIA_PERMIT
ORDER BY 
	1</CommandText>
        <QueryParameters>
          <QueryParameter Name="@P_SORT">
            <Value>=Parameters!P_SORT.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="Col_Sort">
          <DataField>Col_Sort</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Permit">
