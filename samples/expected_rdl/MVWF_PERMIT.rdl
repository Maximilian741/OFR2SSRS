    </DataSet>
    <DataSet Name="Q_ORG">
      <Query>
        <DataSourceName>DS_Main</DataSourceName>
        <CommandText>SELECT 
	SA.Org_Id, 
	SA.Site_Id SA_Site_Id, 
	Pkg_WUTM_Util.F_Format_Org_Name(
		O.Busn_Nm, 
		O.Frst_Nm, 
		O.MI, 
		O.Lst_Nm,
		'FIRST_LAST') Permittee, 
	Pkg_WUTM_Util.F_Format_Address(
		AH.ADRH_Strt_1, 
		AH.ADRH_Strt_2, 
		AH.ADRH_City, 
		AH.ADRH_St, 
		AH.ADRH_Zip_Cd, 
		AH.ADRH_Zip_Plus_Four,
		NULL, --pvCounty
		Pkg_WUTM_Util.F_Format_Org_Name(
			O.Busn_Nm, 
			O.Frst_Nm, 
			O.MI, 
			O.Lst_Nm,
			'FIRST_LAST')) Permittee_Addr
FROM
	Site_Affil_Type SAT, 
	Site_Affiliation SA, 
	Organization O,
	Address_History AH	
WHERE
	SAT.Site_Affil_Type_Id = SA.Site_Affil_Type_Id
	AND SA.Org_Id = O.Org_Id 
	AND SAT.Site_Affil_Type_Name = 'PERM'
	AND O.Org_Id = AH.Org_Id	
	AND AH.AdTyp_Cd = 'M'
	AND EXISTS(
		SELECT *
		FROM
			Address_History_Program_XRef AHPX
		WHERE
			AHPX.Org_Id = AH.Org_id
			AND AHPX.AdTyp_Cd = AH.AdTyp_Cd 
			AND AHPX.Prog_Id = SA.Prog_Id
		HAVING
			MAX(AHPX.ADRH_No) = AH.ADRH_No) 
	AND SA.Prog_Id = :Prog_Id		
	AND SA.Site_Id = :Site_Id 
	AND NVL(TRUNC(SA.Site_Affil_Start_Date), NVL(:Perm_Exp_Date, TRUNC(SYSDATE))) &lt;= NVL(:Perm_Exp_Date, TRUNC(SYSDATE))
	AND NVL(TRUNC(SA.Site_Affil_End_Date), NVL(:Perm_Exp_Date, TRUNC(SYSDATE))) &gt;= NVL(:Perm_Exp_Date, TRUNC(SYSDATE))
ORDER BY
  O.Busn_Nm, 
  O.Lst_Nm,
  O.Frst_Nm</CommandText>
      </Query>
      <Fields>
        <Field Name="PERMITTEE">
          <DataField>PERMITTEE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PERMITTEE_ADDR">
          <DataField>PERMITTEE_ADDR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SA_SITE_ID">
          <DataField>SA_SITE_ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ORG_ID">
          <DataField>ORG_ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Q_SIGNATURE">
      <Query>
        <DataSourceName>DS_Main</DataSourceName>
        <CommandText>SELECT 
	Image Signature
FROM
	DEQ_Image I,
	DEQ_Image_XRef DIX,
	System_Parameters SP, 
	Program P,
	Organization O
WHERE
	I.Image_Id = DIX.Image_Id
	AND DIX.Org_Id = SP.SParm_Num_Val
	AND DIX.Prog_Id = P.Prog_Id
	AND P.Prog_Name = 'JV'
	AND DIX.Org_Id = O.Org_Id 
	AND SP.SParm_Nm = 'WUTMB_CHIEF'</CommandText>
      </Query>
      <Fields>
        <Field Name="Signature">
          <DataField>Signature</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
