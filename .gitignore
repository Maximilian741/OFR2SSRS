instance/

# Optional: ignore generated RDL outputs (keep the canonical sample)
samples/expected_rdl/*.rdl
!samples/expected_rdl/SAMPLE_INSPECTION.rdl

# RenderLab: fetched Microsoft DLLs + rendered verification output
tools/renderlab/lib/
tools/renderlab/out/

# Local scratch runner (never commit)
_scratch_run.py

# Local-only worktree artifacts
.claude/worktrees/

# Claude Code per-machine settings (leaks local username/paths + allowlist)
.claude/settings.local.json
