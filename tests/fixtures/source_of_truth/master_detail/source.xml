    <geometryInfo x="1.50000" y="1.45000" width="2.00000" height="0.26000"/>
    <visualSettings lineWidth="1" linePattern="solid"/>
  </field>
  <field name="PF_P_STATUS" source="P_STATUS" pageNumber="1" minWidowLines="1"
   spacing="0">
    <font size="0"/>
    <geometryInfo x="1.50000" y="1.78000" width="2.00000" height="0.26000"/>
    <visualSettings lineWidth="1" linePattern="solid"/>
