<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <DataSources>
    <DataSource Name="SharedDataSource">
      <DataSourceReference>SharedDataSource</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>00000000-0000-0000-0000-000000000001</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Q_CUSTOMER">
      <Query>
        <DataSourceName>SharedDataSource</DataSourceName>
        <CommandText>SELECT
	C.Cust_Id,
	C.Cust_Name,
	C.City
FROM
	Sample_Customer C
WHERE
	C.Created_Date &gt;= TO_DATE(:P_START_DATE, 'YYYY-MM-DD')
	AND C.Created_Date &lt;= TO_DATE(:P_END_DATE, 'YYYY-MM-DD')
ORDER BY
	C.Cust_Name</CommandText>
        <QueryParameters>
          <QueryParameter Name=":P_START_DATE">
            <Value>=Parameters!P_START_DATE.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":P_END_DATE">
            <Value>=Parameters!P_END_DATE.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="CUST_ID">
          <DataField>CUST_ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CUST_NAME">
          <DataField>CUST_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CITY">
          <DataField>CITY</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Q_ORDER">
      <Query>
        <DataSourceName>SharedDataSource</DataSourceName>
        <CommandText>SELECT CUST_ID,
	O.Order_Id,
	O.Cust_Id,
	TO_CHAR(O.Order_Date, 'MM/DD/YYYY') Order_Dt,
	O.Amount,
	O.Status
FROM
	Sample_Order O
WHERE
	O.Cust_Id = :CUST_ID
ORDER BY
	O.Order_Date</CommandText>
        <QueryParameters>
          <QueryParameter Name=":CUST_ID">
            <Value>=Parameters!CUST_ID.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="ORDER_ID">
          <DataField>ORDER_ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ORDER_DT">
          <DataField>ORDER_DT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AMOUNT">
          <DataField>AMOUNT</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="STATUS">
          <DataField>STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CUST_ID">
          <DataField>CUST_ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="P_START_DATE">
      <DataType>DateTime</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>=Nothing</Value>
        </Values>
      </DefaultValue>
      <Prompt>Start Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="P_END_DATE">
      <DataType>DateTime</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>=Nothing</Value>
        </Values>
      </DefaultValue>
      <Prompt>End Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="P_CITY">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value />
        </Values>
      </DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>City</Prompt>
    </ReportParameter>
    <ReportParameter Name="P_STATUS">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value />
        </Values>
      </DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Status</Prompt>
    </ReportParameter>
    <ReportParameter Name="CUST_ID">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value />
        </Values>
      </DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>CUST_ID</Prompt>
    </ReportParameter>
  </ReportParameters>
