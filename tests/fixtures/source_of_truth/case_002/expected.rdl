  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>BETA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name=":p_perm_num">
            <Value>=Parameters!p_perm_num.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT p.perm_num, p.perm_name,  

       LTRIM(SUBSTR(p.perm_name,6),'0') Lic_No, 

       UPPER(PT.PERM_TYPE_DESC) as PERM_TYPE_DESC, 

       pt.perm_type_name, 

       site.site_id,  

       SUBSTR(site.site_name,1,25) site_name,  

       site_name facility, 

       DECODE(gli.addr_strt_1, NULL, gli.directions, gli.addr_strt_1) geo_desc 

  FROM permit p, 

       permit_type pt, 

       status_type st, 

       site_affiliation sa, 

       application a, 

       site, 

       geo_loc_info gli 

 WHERE pt.perm_type_name in ('CMVGY','MVWF')  

   and pt.prog_id = 100054 

   and NVL(pt.void_ind,'N') = 'N' 

   and pt.perm_type_id = p.perm_type_id 

   and p.perm_num = NVL(:p_perm_num, p.perm_num) 

   and p.prog_id = pt.prog_id 

   and p.stat_type_id = st.stat_type_id 

   and st.stat_type_name = 'JVA' 

   and st.prog_id = p.prog_id 

   and st.functional_ctg = 'P' 

   and NVL(st.void_ind,'N') = 'N' 

   and a.perm_num = p.perm_num 

   and a.site_affil_id = sa.site_affil_id 

   and sa.site_affil_type_id = 5 

   and sa.site_id = site.site_id 

   and gli.site_id = site.site_id 

 order by perm_type_desc, p.perm_name</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="PERM_NUM">
          <DataField>PERM_NUM</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="PERM_NAME">
          <DataField>PERM_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LIC_NO">
          <DataField>LIC_NO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PERM_TYPE_DESC">
          <DataField>PERM_TYPE_DESC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PERM_TYPE_NAME">
          <DataField>PERM_TYPE_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITE_ID">
          <DataField>SITE_ID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="SITE_NAME">
          <DataField>SITE_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FACILITY">
          <DataField>FACILITY</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="GEO_DESC">
          <DataField>GEO_DESC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="LicenseeInfo">
      <Query>
        <DataSourceName>BETA</DataSourceName>
        <CommandText>SELECT DISTINCT
  sa.site_id,
  DECODE(ot.category, 'B', o.busn_nm, o.frst_nm || ' ' || o.lst_nm) AS licensee,
  ah.adrh_strt_1,
  ah.adrh_city,
  ah.adrh_st,
  ah.adrh_zip_cd,
  ah.adrh_zip_plus_four
FROM site_affiliation sa
JOIN organization o ON sa.org_id = o.org_id
JOIN org_type ot ON o.org_type_id = ot.org_type_id
JOIN address_history ah ON sa.org_id = ah.org_id
WHERE sa.prog_id = 100054
  AND sa.site_affil_type_id = 3
  AND NVL(sa.site_affil_end_date, SYSDATE) &gt;= SYSDATE
  AND ah.adtyp_cd = 'M'
  AND ah.adrh_no = (
    SELECT MAX(ah1.adrh_no)
    FROM address_history ah1
    WHERE ah1.org_id = ah.org_id
      AND ah1.adtyp_cd = ah.adtyp_cd
  )</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SITE_ID">
          <DataField>SITE_ID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="LICENSEE">
          <DataField>LICENSEE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADRH_STRT_1">
          <DataField>ADRH_STRT_1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADRH_CITY">
          <DataField>ADRH_CITY</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADRH_ST">
          <DataField>ADRH_ST</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADRH_ZIP_CD">
          <DataField>ADRH_ZIP_CD</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADRH_ZIP_PLUS_FOUR">
          <DataField>ADRH_ZIP_PLUS_FOUR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>BETA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name=":p_perm_num">
            <Value>=Parameters!p_perm_num.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
  p.perm_num,
  p.perm_name,
  LTRIM(SUBSTR(p.perm_name, 6), '0') AS Lic_No,
  UPPER(pt.perm_type_desc) AS perm_type_desc,
  pt.perm_type_name,
  site.site_id,
  SUBSTR(site.site_name, 1, 25) AS site_name,
  site.site_name AS facility,
  DECODE(gli.addr_strt_1, NULL, gli.directions, gli.addr_strt_1) AS geo_desc,
  DECODE(ot.category, 'B', o.busn_nm, o.frst_nm || ' ' || o.lst_nm) AS licensee,
  ah.adrh_strt_1,
  ah.adrh_city,
  ah.adrh_st,
  ah.adrh_zip_cd,
  ah.adrh_zip_plus_four
FROM permit p
JOIN permit_type pt ON pt.perm_type_id = p.perm_type_id AND pt.prog_id = 100054 AND NVL(pt.void_ind, 'N') = 'N'
JOIN status_type st ON p.stat_type_id = st.stat_type_id AND st.stat_type_name = 'JVA' AND st.prog_id = p.prog_id AND st.functional_ctg = 'P' AND NVL(st.void_ind, 'N') = 'N'
JOIN application a ON a.perm_num = p.perm_num
JOIN site_affiliation sa ON a.site_affil_id = sa.site_affil_id AND sa.site_affil_type_id = 5
JOIN site ON sa.site_id = site.site_id
JOIN geo_loc_info gli ON gli.site_id = site.site_id
-- Join to get licensee info
JOIN site_affiliation sa2 ON sa2.site_id = site.site_id AND sa2.prog_id = 100054 AND sa2.site_affil_type_id = 3 AND NVL(sa2.site_affil_end_date, SYSDATE) &gt;= SYSDATE
JOIN organization o ON sa2.org_id = o.org_id
JOIN org_type ot ON o.org_type_id = ot.org_type_id
JOIN address_history ah ON sa2.org_id = ah.org_id AND ah.adtyp_cd = 'M'
WHERE pt.perm_type_name IN ('CMVGY', 'MVWF')
  AND p.perm_num = NVL(:p_perm_num, p.perm_num)
  AND ah.adrh_no = (
    SELECT MAX(ah1.adrh_no)
    FROM address_history ah1
    WHERE ah1.org_id = ah.org_id
      AND ah1.adtyp_cd = ah.adtyp_cd
  )
ORDER BY perm_type_desc, p.perm_name
</CommandText>
      </Query>
