<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <DataSources>
    <DataSource Name="SharedDataSource">
      <DataSourceReference>SharedDataSource</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>00000000-0000-0000-0000-000000000001</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Q_MAIN">
      <Query>
        <DataSourceName>SharedDataSource</DataSourceName>
        <CommandText>SELECT
	R.Recipient_Id,
	R.Recipient_Name,
	R.Address_Line,
	R.City_State_Zip
FROM
	Sample_Recipient R
WHERE
	R.Recipient_Id = :P_RECIPIENT_ID</CommandText>
        <QueryParameters>
          <QueryParameter Name=":P_RECIPIENT_ID">
            <Value>=Parameters!P_RECIPIENT_ID.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="RECIPIENT_ID">
          <DataField>RECIPIENT_ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RECIPIENT_NAME">
          <DataField>RECIPIENT_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADDRESS_LINE">
          <DataField>ADDRESS_LINE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CITY_STATE_ZIP">
          <DataField>CITY_STATE_ZIP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="P_RECIPIENT_ID">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value />
        </Values>
      </DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Recipient Id</Prompt>
    </ReportParameter>
    <ReportParameter Name="P_REGION">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value />
        </Values>
      </DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Region</Prompt>
    </ReportParameter>
  </ReportParameters>
