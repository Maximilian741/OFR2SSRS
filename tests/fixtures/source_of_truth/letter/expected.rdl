                              <Height>0.18in</Height>
                            </Textbox>
                            <Textbox Name="RecP_Tb_9">
                              <Paragraphs>
                                <Paragraph>
                                  <Style>
                                    <TextAlign>Left</TextAlign>
                                  </Style>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>="This letter confirms the current status of your sample account for the reporting" &amp; vbCrLf &amp; "period indicated above. Our records show that all required materials were received."</Value>
                                      <Style>
                                        <FontSize>10pt</FontSize>
                                        <Color>#111111</Color>
                                      </Style>
                                    </TextRun>
                                  </TextRuns>
                                </Paragraph>
