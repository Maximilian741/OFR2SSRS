                                  <Color>#ffffff</Color>
                                  <Width>0.5pt</Width>
                                </Border>
                                <VerticalAlign>Top</VerticalAlign>
                                <PaddingLeft>2pt</PaddingLeft>
                                <PaddingRight>2pt</PaddingRight>
                                <PaddingTop>2pt</PaddingTop>
                                <PaddingBottom>2pt</PaddingBottom>
                              </Style>
                              <CanGrow>true</CanGrow>
                              <KeepTogether>true</KeepTogether>
                              <Top>3.00in</Top>
                              <Left>0.02in</Left>
                              <Width>7.00in</Width>
                              <Height>0.60in</Height>
                            </Textbox>
                            <Textbox Name="RecP_Tb_10">
                              <Paragraphs>
                                <Paragraph>
                                  <Style>
                                    <TextAlign>Left</TextAlign>
                                  </Style>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>="No further action is required on your part at this time. If any information in this" &amp; vbCrLf &amp; "notice appears to be inaccurate, please contact the sample office within thirty days."</Value>
                                      <Style>
                                        <FontSize>10pt</FontSize>
                                        <Color>#111111</Color>
                                      </Style>
                                    </TextRun>
                                  </TextRuns>
                                </Paragraph>
                              </Paragraphs>
