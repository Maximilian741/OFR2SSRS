    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>BETA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name=":ORG_ID">
            <Value>=Parameters!ORG_ID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT VOC.ORG_NAME
