    <DataSet Name="DataSet4">
      <Query>
        <DataSourceName>BETA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name=":METH_ID">
            <Value>=Parameters!METH_ID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT ACT.ACTION_TYPE_DESC
FROM ACTION_HISTORY AH
JOIN ACTION_TYPE ACT ON AH.ACTION_TYPE_ID = ACT.ACTION_TYPE_ID
WHERE AH.METH_ID = :METH_ID</CommandText>
        <Timeout>2</Timeout>
      </Query>
      <Fields>
        <Field Name="ACTION_TYPE_DESC">
          <DataField>ACTION_TYPE_DESC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet5">
      <Query>
        <DataSourceName>BETA</DataSourceName>
        <CommandText>
SELECT 
    C.CNTY_NM AS CountyName,
    COUNT(DISTINCT VMH.CVID) AS CountCVIDPerCN
FROM 
    V_METH_HEADER VMH
    JOIN COUNTIES C ON VMH.CNTY_ID = C.CNTY_ID
GROUP BY 
    C.CNTY_NM
ORDER BY 
    C.CNTY_NM
</CommandText>
        <Timeout>3</Timeout>
      </Query>
      <Fields>
        <Field Name="COUNTYNAME">
          <DataField>COUNTYNAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COUNTCVIDPERCN">
          <DataField>COUNTCVIDPERCN</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
