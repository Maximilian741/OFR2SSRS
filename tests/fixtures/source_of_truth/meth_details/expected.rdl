  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>BETA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name=":PARM_CVID">
            <Value>=Parameters!PARM_CVID.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_ADDR_CITY">
            <Value>=Parameters!PARM_ADDR_CITY.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_CNTY">
            <Value>=Parameters!PARM_CNTY.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_STAT_TYPE_DESC">
            <Value>=Parameters!PARM_STAT_TYPE_DESC.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_OWNER">
            <Value>=Parameters!PARM_OWNER.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_CONTRACTOR">
            <Value>=Parameters!PARM_CONTRACTOR.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_ACTION_TYPE_ID">
            <Value>=Parameters!PARM_ACTION_TYPE_ID.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":P_ACTION_HIST_ID">
            <Value>=Parameters!P_ACTION_HIST_ID.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":P_METH_ID">
            <Value>=Parameters!P_METH_ID.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_RECVD_START_DT">
            <Value>=Parameters!PARM_RECVD_START_DT.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_RECVD_END_DT">
            <Value>=Parameters!PARM_RECVD_END_DT.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_REFERRED_START_DT">
            <Value>=Parameters!PARM_REFERRED_START_DT.Value</Value>
          </QueryParameter>
          <QueryParameter Name=":PARM_REFERRED_END_DT">
            <Value>=Parameters!PARM_REFERRED_END_DT.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT 
    VMH.CVID,
    VMH.METH_ID,
    VMH.OWNER,
    VMH.STAT_TYPE_ID,
    UPPER(ST.STAT_TYPE_DESC) AS STAT_TYPE_DESC_UPPER,
    ST.STAT_TYPE_DESC,
    AH.STATUS_DATE,
    AH.ACTION_TYPE_ID,
    ACT.ACTION_TYPE_DESC,
    ACT.ACTION_TYPE_NAME,
    AH.ACTION_HIST_ID,
    AH.ACTION_HIST_DESCR,
    VMH.SITE_ID,
    VMH.SITE_NAME,
    VMH.INCIDENT_SITE_NAME,
    C.CNTY_NM,
    VMH.ADDR_CITY,
    VMH.LOCATION,
    VMH.COMPLNT_RECVD_DT,
    VMH.COMPLNT_OBSERVED_DT,
    VMH.COMPLNT_REFERRED_DT,
    M.ORG_ID,
    VMH.CNTY_ID
FROM 
    ACTION_HISTORY AH
    LEFT JOIN ACTION_TYPE ACT ON AH.ACTION_TYPE_ID = ACT.ACTION_TYPE_ID
    LEFT JOIN V_METH_HEADER VMH ON AH.METH_ID = VMH.METH_ID
    LEFT JOIN STATUS_TYPE ST ON VMH.STAT_TYPE_ID = ST.STAT_TYPE_ID
    LEFT JOIN MEMBER M ON VMH.METH_ID = M.METH_ID
    LEFT JOIN ORGANIZATION O ON VMH.OWNER = O.ORG_ID
    LEFT JOIN COUNTIES C ON VMH.CNTY_ID = C.CNTY_ID
WHERE 
    (:PARM_CVID IS NULL OR VMH.CVID IN (:PARM_CVID))
    AND (:PARM_ADDR_CITY IS NULL OR VMH.ADDR_CITY IN (:PARM_ADDR_CITY))
    AND (:PARM_CNTY IS NULL OR C.CNTY_NM IN (:PARM_CNTY))
    AND (:PARM_STAT_TYPE_DESC IS NULL OR UPPER(ST.STAT_TYPE_DESC) IN (UPPER(:PARM_STAT_TYPE_DESC)))
    AND (:PARM_OWNER IS NULL OR VMH.OWNER = :PARM_OWNER)
    AND (:PARM_CONTRACTOR IS NULL OR M.ORG_ID = :PARM_CONTRACTOR)
    AND (:PARM_ACTION_TYPE_ID IS NULL OR AH.ACTION_TYPE_ID IN (:PARM_ACTION_TYPE_ID))
    AND (:P_ACTION_HIST_ID IS NULL OR AH.ACTION_HIST_ID = :P_ACTION_HIST_ID)
    AND (:P_METH_ID IS NULL OR AH.METH_ID = :P_METH_ID)
    AND TRUNC(NVL(VMH.COMPLNT_RECVD_DT, SYSDATE)) BETWEEN 
        TRUNC(NVL(TO_DATE(:PARM_RECVD_START_DT, 'YYYY-MM-DD'), TO_DATE('1800-01-01', 'YYYY-MM-DD'))) AND 
        TRUNC(NVL(TO_DATE(:PARM_RECVD_END_DT, 'YYYY-MM-DD'), SYSDATE))
    AND TRUNC(NVL(VMH.COMPLNT_REFERRED_DT, SYSDATE)) BETWEEN 
        TRUNC(NVL(TO_DATE(:PARM_REFERRED_START_DT, 'YYYY-MM-DD'), TO_DATE('1800-01-01', 'YYYY-MM-DD'))) AND 
        TRUNC(NVL(TO_DATE(:PARM_REFERRED_END_DT, 'YYYY-MM-DD'), SYSDATE))</CommandText>
        <Timeout>3</Timeout>
      </Query>
      <Fields>
        <Field Name="CVID">
          <DataField>CVID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="METH_ID">
          <DataField>METH_ID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
